generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String        @id @default(cuid())
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        User[]
  projects     Project[]
  investors    Investor[]
  investments  Investment[]
  returns      Return[]
  documents    Document[]
  interactions Interaction[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  password       String
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  status         ProjectStatus @default(EM_CAPTACAO)
  location       String?
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  investments    Investment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Investor {
  id             String         @id @default(cuid())
  name           String
  email          String?
  phone          String?
  status         InvestorStatus @default(PROSPECTO)
  entryDate      DateTime?
  notes          String?
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  investments    Investment[]
  documents      Document[]
  interactions   Interaction[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Investment {
  id             String         @id @default(cuid())
  amount         Float
  date           DateTime
  type           InvestmentType @default(FINANCEIRO)
  notes          String?
  investorId     String
  investor       Investor       @relation(fields: [investorId], references: [id])
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id])
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  returns        Return[]
  documents      Document[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Return {
  id             String       @id @default(cuid())
  expectedAmount Float
  expectedDate   DateTime
  realizedDate   DateTime?
  realizedAmount Float?
  status         ReturnStatus @default(PENDENTE)
  investmentId   String
  investment     Investment   @relation(fields: [investmentId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Document {
  id             String           @id @default(cuid())
  name           String
  fileUrl        String
  category       DocumentCategory @default(OUTRO)
  investorId     String?
  investor       Investor?        @relation(fields: [investorId], references: [id])
  investmentId   String?
  investment     Investment?      @relation(fields: [investmentId], references: [id])
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Interaction {
  id             String          @id @default(cuid())
  date           DateTime
  type           InteractionType @default(OUTRO)
  summary        String
  nextStep       String?
  investorId     String
  investor       Investor        @relation(fields: [investorId], references: [id])
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum ProjectStatus {
  EM_CAPTACAO
  EM_OBRA
  ENTREGUE
  CANCELADO
}

enum InvestorStatus {
  ATIVO
  PROSPECTO
  INATIVO
}

enum InvestmentType {
  FINANCEIRO
  PERMUTA
  OUTRO
}

enum ReturnStatus {
  PENDENTE
  PAGO
  ATRASADO
}

enum DocumentCategory {
  CONTRATO
  COMPROVANTE
  OUTRO
}

enum InteractionType {
  REUNIAO
  LIGACAO
  WHATSAPP
  EMAIL
  OUTRO
}
